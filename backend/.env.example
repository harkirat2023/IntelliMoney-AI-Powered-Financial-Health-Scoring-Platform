APP_NAME=IntelliMoney
ENVIRONMENT=development
SECRET_KEY=change-this-secret-key
VERSION=1.0.0
ACCESS_TOKEN_EXPIRE_MINUTES=1440
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=intellimoney
REDIS_URL=
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# REQUIRED: Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BANK_ENCRYPTION_KEY=
BANK_CONSENT_REDIRECT_BASE=http://localhost:5173/connect-bank/consent

# REQUIRED: Your LLM API key for AI Copilot features
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.3
OPENAI_MAX_TOKENS=1024
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# When true, ML pipeline falls back to keyword matching if the model is missing
ML_ALLOW_FALLBACK=false

# Upload storage (local by default; set SUPABASE_URL + SUPABASE_SERVICE_KEY for production)
UPLOAD_DIR=uploads/receipts
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
