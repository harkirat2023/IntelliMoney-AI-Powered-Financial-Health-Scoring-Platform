APP_NAME=IntelliMoney
ENVIRONMENT=development
SECRET_KEY=change-this-secret-key
VERSION=1.0.0
ACCESS_TOKEN_EXPIRE_MINUTES=1440
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=intellimoney
REDIS_URL=
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3002,http://localhost:8080,http://localhost:8000

# REQUIRED: Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BANK_ENCRYPTION_KEY=2Fz0GyGP90qyAXzaweseHhlNxIMS7bcjEGdHP4Vh8-o=
BANK_CONSENT_REDIRECT_BASE=http://localhost:5173/connect-bank/consent

# REQUIRED: Your Groq API key for AI Copilot features (get one at https://console.groq.com/keys)
GROQ_API_KEY=
GROQ_API_BASE=https://api.groq.com/openai/v1
GROQ_MODEL=llama3-8b-8192
GROQ_TEMPERATURE=0.3
GROQ_MAX_TOKENS=1024

# When true, ML pipeline falls back to keyword matching if the model is missing
ML_ALLOW_FALLBACK=false

# Upload storage (local by default; set SUPABASE_URL + SUPABASE_SERVICE_KEY for production)
UPLOAD_DIR=uploads/receipts
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
