APP_NAME=IntelliMoney
ENVIRONMENT=development
SECRET_KEY=change-this-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=1440
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=intellimoney
REDIS_URL=
LOG_LEVEL=INFO

# REQUIRED: Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BANK_ENCRYPTION_KEY=

# REQUIRED: Your OpenAI API key for AI Copilot features
OPENAI_API_KEY=

# Optional OpenAI settings (defaults shown)
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.3
OPENAI_MAX_TOKENS=1024
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Bank consent redirect (change to your frontend URL)
BANK_CONSENT_REDIRECT_BASE=http://localhost:5173/connect-bank/consent
